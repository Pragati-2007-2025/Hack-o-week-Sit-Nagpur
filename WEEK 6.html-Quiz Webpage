<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BRAINWAVE | Quiz Challenge</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0f0f1a;
            --bg-secondary: #1a1a2e;
            --bg-card: #16213e;
            --bg-option: #1f2a48;
            --accent-purple: #a855f7;
            --accent-pink: #ec4899;
            --accent-blue: #3b82f6;
            --accent-cyan: #06b6d4;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --accent-yellow: #f59e0b;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-effects {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }

        .bg-circle {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.3;
            animation: float 20s ease-in-out infinite;
        }

        .bg-circle:nth-child(1) {
            width: 500px;
            height: 500px;
            background: var(--accent-purple);
            top: -200px;
            right: -100px;
            animation-delay: 0s;
        }

        .bg-circle:nth-child(2) {
            width: 400px;
            height: 400px;
            background: var(--accent-pink);
            bottom: -150px;
            left: -100px;
            animation-delay: -5s;
        }

        .bg-circle:nth-child(3) {
            width: 300px;
            height: 300px;
            background: var(--accent-blue);
            top: 50%;
            left: 50%;
            animation-delay: -10s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(30px, -30px) scale(1.1); }
            50% { transform: translate(-20px, 20px) scale(0.9); }
            75% { transform: translate(20px, 30px) scale(1.05); }
        }

        /* Header */
        .header {
            position: relative;
            z-index: 1;
            padding: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 900px;
            margin: 0 auto;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.3rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .timer-display {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--bg-card);
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600;
        }

        .timer-icon {
            color: var(--accent-cyan);
        }

        .timer-value {
            font-size: 1.2rem;
            min-width: 50px;
        }

        .timer-value.warning {
            color: var(--accent-yellow);
            animation: pulse 0.5s ease-in-out infinite;
        }

        .timer-value.danger {
            color: var(--accent-red);
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* Main Container */
        .container {
            position: relative;
            z-index: 1;
            max-width: 900px;
            margin: 0 auto;
            padding: 0 2rem 4rem;
        }

        /* Progress Bar */
        .progress-container {
            margin-bottom: 3rem;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .progress-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .progress-score {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600;
            color: var(--accent-purple);
        }

        .progress-bar {
            height: 6px;
            background: var(--bg-card);
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-purple), var(--accent-pink));
            border-radius: 10px;
            transition: width 0.5s ease;
        }

        /* Question Card */
        .question-card {
            background: var(--bg-card);
            border-radius: 24px;
            padding: 2.5rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .question-meta {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .question-number {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--accent-purple);
            background: rgba(168, 85, 247, 0.15);
            padding: 0.4rem 1rem;
            border-radius: 50px;
        }

        .question-category {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--accent-cyan);
            background: rgba(6, 182, 212, 0.15);
            padding: 0.4rem 1rem;
            border-radius: 50px;
        }

        .question-text {
            font-size: 1.5rem;
            font-weight: 600;
            line-height: 1.4;
            margin-bottom: 2rem;
        }

        /* Options */
        .options-container {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .option {
            position: relative;
            background: var(--bg-option);
            border: 2px solid transparent;
            border-radius: 16px;
            padding: 1.25rem 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .option:hover:not(.disabled) {
            background: rgba(31, 42, 72, 0.8);
            border-color: rgba(168, 85, 247, 0.3);
            transform: translateX(5px);
        }

        .option.selected {
            border-color: var(--accent-purple);
            background: rgba(168, 85, 247, 0.15);
        }

        .option.correct {
            border-color: var(--accent-green);
            background: rgba(16, 185, 129, 0.15);
        }

        .option.incorrect {
            border-color: var(--accent-red);
            background: rgba(239, 68, 68, 0.15);
        }

        .option.disabled {
            cursor: default;
            opacity: 0.7;
        }

        .option-letter {
            width: 40px;
            height: 40px;
            background: var(--bg-card);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            flex-shrink: 0;
            transition: all 0.3s;
        }

        .option.selected .option-letter {
            background: var(--accent-purple);
        }

        .option.correct .option-letter {
            background: var(--accent-green);
        }

        .option.incorrect .option-letter {
            background: var(--accent-red);
        }

        .option-text {
            font-size: 1.1rem;
            font-weight: 500;
        }

        .option-icon {
            margin-left: auto;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .option.selected .option-icon,
        .option.correct .option-icon,
        .option.incorrect .option-icon {
            opacity: 1;
        }

        /* Buttons */
        .btn-group {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
        }

        .btn {
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            padding: 1rem 2rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(168, 85, 247, 0.4);
        }

        .btn-secondary {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-secondary:hover {
            background: var(--bg-option);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
        }

        /* Results Screen */
        .results-screen {
            display: none;
            text-align: center;
            padding: 3rem 0;
        }

        .results-screen.active {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results-circle {
            width: 200px;
            height: 200px;
            margin: 0 auto 2rem;
            position: relative;
        }

        .results-circle svg {
            transform: rotate(-90deg);
        }

        .results-circle-bg {
            fill: none;
            stroke: var(--bg-card);
            stroke-width: 12;
        }

        .results-circle-fill {
            fill: none;
            stroke: url(#gradient);
            stroke-width: 12;
            stroke-linecap: round;
            stroke-dasharray: 565;
            stroke-dashoffset: 565;
            transition: stroke-dashoffset 1.5s ease;
        }

        .results-score {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .results-score-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 3.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .results-score-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .results-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .results-message {
            color: var(--text-secondary);
            font-size: 1.1rem;
            margin-bottom: 2rem;
        }

        .results-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 1.5rem;
            border-radius: 16px;
            text-align: center;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
        }

        .stat-icon.correct {
            background: rgba(16, 185, 129, 0.15);
            color: var(--accent-green);
        }

        .stat-icon.incorrect {
            background: rgba(239, 68, 68, 0.15);
            color: var(--accent-red);
        }

        .stat-icon.skipped {
            background: rgba(245, 158, 11, 0.15);
            color: var(--accent-yellow);
        }

        .stat-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .results-actions {
            display: flex;
            justify-content: center;
            gap: 1rem;
        }

        /* Quiz Start Screen */
        .start-screen {
            text-align: center;
            padding: 4rem 2rem;
        }

        .start-screen.active {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        .start-icon {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-pink));
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
        }

        .start-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .start-subtitle {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin-bottom: 3rem;
        }

        .quiz-info {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-bottom: 3rem;
        }

        .info-item {
            text-align: center;
        }

        .info-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--accent-purple);
        }

        .info-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .quiz-rules {
            background: var(--bg-card);
            padding: 2rem;
            border-radius: 16px;
            text-align: left;
            max-width: 500px;
            margin: 0 auto 3rem;
        }

        .rules-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .rules-list {
            list-style: none;
        }

        .rules-list li {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            padding: 0.5rem 0;
            color: var(--text-secondary);
        }

        .rules-list li svg {
            color: var(--accent-cyan);
            flex-shrink: 0;
        }

        /* Quiz Container */
        .quiz-screen {
            display: none;
        }

        .quiz-screen.active {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 1rem;
            }

            .question-text {
                font-size: 1.2rem;
            }

            .results-stats {
                grid-template-columns: 1fr;
            }

            .quiz-info {
                flex-direction: column;
                gap: 1.5rem;
            }

            .btn-group {
                flex-direction: column;
            }

            .results-actions {
                flex-direction: column;
            }
        }

        /* Hidden state */
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <!-- Background Effects -->
    <div class="bg-effects">
        <div class="bg-circle"></div>
        <div class="bg-circle"></div>
        <div class="bg-circle"></div>
    </div>

    <!-- SVG Gradient Definition -->
    <svg width="0" height="0" style="position: absolute;">
        <defs>
            <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#a855f7"/>
                <stop offset="100%" stop-color="#ec4899"/>
            </linearGradient>
        </defs>
    </svg>

    <!-- Header -->
    <header class="header">
        <div class="logo">
            <div class="logo-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <path d="M12 2a8 8 0 0 1 8 8c0 3-1.5 5.5-4 7v3H8v-3c-2.5-1.5-4-4-4-7a8 8 0 0 1 8-8z"/>
                    <path d="M9 22h6"/>
                    <path d="M12 17v5"/>
                </svg>
            </div>
            <span class="logo-text">BRAINWAVE</span>
        </div>
        <div class="timer-display" id="timerDisplay">
            <svg class="timer-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
            </svg>
            <span class="timer-value" id="timerValue">05:00</span>
        </div>
    </header>

    <!-- Main Container -->
    <main class="container">
        
        <!-- Start Screen -->
        <div class="start-screen active" id="startScreen">
            <div class="start-icon">
                <svg width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 17h.01"/>
                </svg>
            </div>
            <h1 class="start-title">General Knowledge Quiz</h1>
            <p class="start-subtitle">Test your knowledge with 5 questions</p>
            
            <div class="quiz-info">
                <div class="info-item">
                    <div class="info-value">5</div>
                    <div class="info-label">Questions</div>
                </div>
                <div class="info-item">
                    <div class="info-value">5</div>
                    <div class="info-label">Minutes</div>
                </div>
                <div class="info-item">
                    <div class="info-value">100%</div>
                    <div class="info-label">To Pass</div>
                </div>
            </div>

            <div class="quiz-rules">
                <h3 class="rules-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                        <path d="M12 16v-4"/>
                        <path d="M12 8h.01"/>
                    </svg>
                    Quiz Rules
                </h3>
                <ul class="rules-list">
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Each question has only one correct answer
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        You have 1 minute per question
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Answers can be changed before submission
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        No going back after finishing
                    </li>
                </ul>
            </div>

            <button class="btn btn-primary" onclick="startQuiz()">
                Start Quiz
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>
        </div>

        <!-- Quiz Screen -->
        <div class="quiz-screen" id="quizScreen">
            <!-- Progress -->
            <div class="progress-container">
                <div class="progress-header">
                    <span class="progress-label">Question <span id="currentQ">1</span> of <span id="totalQ">5</span></span>
                    <span class="progress-score">Score: <span id="currentScore">0</span>/5</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill" style="width: 20%"></div>
                </div>
            </div>

            <!-- Question Card -->
            <div class="question-card">
                <div class="question-meta">
                    <span class="question-number" id="qNumber">Q1</span>
                    <span class="question-category" id="qCategory">Science</span>
                </div>
                <h2 class="question-text" id="qText">Loading question...</h2>
                
                <div class="options-container" id="optionsContainer">
                    <!-- Options will be inserted here -->
                </div>
            </div>

            <!-- Navigation -->
            <div class="btn-group">
                <button class="btn btn-secondary" id="prevBtn" onclick="prevQuestion()" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    Previous
                </button>
                <button class="btn btn-primary" id="nextBtn" onclick="nextQuestion()">
                    Next
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Results Screen -->
        <div class="results-screen" id="resultsScreen">
            <div class="results-circle">
                <svg width="200" height="200" viewBox="0 0 200 200">
                    <circle class="results-circle-bg" cx="100" cy="100" r="90"/>
                    <circle class="results-circle-fill" id="resultsCircle" cx="100" cy="100" r="90"/>
                </svg>
                <div class="results-score">
                    <div class="results-score-value" id="finalScore">0</div>
                    <div class="results-score-label">out of 5</div>
                </div>
            </div>

            <h2 class="results-title" id="resultsTitle">Great Effort!</h2>
            <p class="results-message" id="resultsMessage">You're on your way to mastery!</p>

            <div class="results-stats">
                <div class="stat-card">
                    <div class="stat-icon correct">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <div class="stat-value" id="correctCount">0</div>
                    <div class="stat-label">Correct</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon incorrect">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </div>
                    <div class="stat-value" id="incorrectCount">0</div>
                    <div class="stat-label">Incorrect</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon skipped">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="8" y1="12" x2="16" y2="12"/>
                        </svg>
                    </div>
                    <div class="stat-value" id="skippedCount">0</div>
                    <div class="stat-label">Skipped</div>
                </div>
            </div>

            <div class="results-actions">
                <button class="btn btn-secondary" onclick="reviewAnswers()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                    Review Answers
                </button>
                <button class="btn btn-primary" onclick="restartQuiz()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 4v6h-6"/>
                        <path d="M1 20v-6h6"/>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                    </svg>
                    Try Again
                </button>
            </div>
        </div>

    </main>

    <script>
        // Quiz Data
        const questions = [
            {
                question: "What is the chemical symbol for gold?",
                options: ["Ag", "Au", "Go", "Gd"],
                correct: 1,
                category: "Science"
            },
            {
                question: "Which planet is known as the 'Red Planet'?",
                options: ["Venus", "Mars", "Jupiter", "Saturn"],
                correct: 1,
                category: "Space"
            },
            {
                question: "What is the largest ocean on Earth?",
                options: ["Atlantic Ocean", "Indian Ocean", "Pacific Ocean", "Arctic Ocean"],
                correct: 2,
                category: "Geography"
            },
            {
                question: "Who painted the Mona Lisa?",
                options: ["Vincent van Gogh", "Pablo Picasso", "Leonardo da Vinci", "Michelangelo"],
                correct: 2,
                category: "History"
            },
            {
                question: "What is the square root of 144?",
                options: ["10", "11", "12", "14"],
                correct: 2,
                category: "Mathematics"
            }
        ];

        // State
        let currentQuestion = 0;
        let answers = new Array(questions.length).fill(null);
        let score = 0;
        let timerInterval = null;
        let timeRemaining = 300; // 5 minutes in seconds

        const letters = ['A', 'B', 'C', 'D'];

        // Initialize
        function startQuiz() {
            document.getElementById('startScreen').classList.remove('active');
            document.getElementById('quizScreen').classList.add('active');
            document.getElementById('totalQ').textContent = questions.length;
            loadQuestion();
            startTimer();
        }

        // Timer
        function startTimer() {
            updateTimerDisplay();
            timerInterval = setInterval(() => {
                timeRemaining--;
                updateTimerDisplay();
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    finishQuiz();
                }
            }, 1000);
        }

        function updateTimerDisplay() {
            const minutes = Math.floor(timeRemaining / 60);
            const seconds = timeRemaining % 60;
            const display = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            const timerEl = document.getElementById('timerValue');
            timerEl.textContent = display;
            
            timerEl.classList.remove('warning', 'danger');
            if (timeRemaining <= 30) {
                timerEl.classList.add('danger');
            } else if (timeRemaining <= 60) {
                timerEl.classList.add('warning');
            }
        }

        // Load Question
        function loadQuestion() {
            const q = questions[currentQuestion];
            document.getElementById('currentQ').textContent = currentQuestion + 1;
            document.getElementById('qNumber').textContent = `Q${currentQuestion + 1}`;
            document.getElementById('qCategory').textContent = q.category;
            document.getElementById('qText').textContent = q.question;
            document.getElementById('progressFill').style.width = `${((currentQuestion + 1) / questions.length) * 100}%`;

            const optionsContainer = document.getElementById('optionsContainer');
            optionsContainer.innerHTML = '';

            q.options.forEach((option, index) => {
                const optionEl = document.createElement('div');
                optionEl.className = 'option';
                if (answers[currentQuestion] === index) {
                    optionEl.classList.add('selected');
                }
                optionEl.innerHTML = `
                    <div class="option-letter">${letters[index]}</div>
                    <span class="option-text">${option}</span>
                    <div class="option-icon">
                        ${answers[currentQuestion] === index ? `
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-purple)" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        ` : ''}
                    </div>
                `;
                optionEl.onclick = () => selectOption(index);
                optionsContainer.appendChild(optionEl);
            });

            // Update nav buttons
            document.getElementById('prevBtn').disabled = currentQuestion === 0;
            
            const nextBtn = document.getElementById('nextBtn');
            if (currentQuestion === questions.length - 1) {
                nextBtn.innerHTML = `
                    Finish Quiz
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                `;
            } else {
                nextBtn.innerHTML = `
                    Next
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                `;
            }
        }

        // Select Option
        function selectOption(index) {
            answers[currentQuestion] = index;
            loadQuestion();
        }

        // Navigation
        function prevQuestion() {
            if (currentQuestion > 0) {
                currentQuestion--;
                loadQuestion();
            }
        }

        function nextQuestion() {
            if (currentQuestion < questions.length - 1) {
                currentQuestion++;
                loadQuestion();
            } else {
                finishQuiz();
            }
        }

        // Finish Quiz
        function finishQuiz() {
            clearInterval(timerInterval);
            
            // Calculate score
            score = 0;
            let correct = 0, incorrect = 0, skipped = 0;
            
            answers.forEach((answer, index) => {
                if (answer === null) {
                    skipped++;
                } else if (answer === questions[index].correct) {
                    score++;
                    correct++;
                } else {
                    incorrect++;
                }
            });

            // Show results
            document.getElementById('quizScreen').classList.remove('active');
            document.getElementById('resultsScreen').classList.add('active');
            
            document.getElementById('finalScore').textContent = score;
            document.getElementById('correctCount').textContent = correct;
            document.getElementById('incorrectCount').textContent = incorrect;
            document.getElementById('skippedCount').textContent = skipped;

            // Update results message
            const resultsTitle = document.getElementById('resultsTitle');
            const resultsMessage = document.getElementById('resultsMessage');
            
            if (score === 5) {
                resultsTitle.textContent = "Perfect Score!";
                resultsMessage.textContent = "You're a true genius! Flawless performance!";
            } else if (score >= 4) {
                resultsTitle.textContent = "Excellent Work!";
                resultsMessage.textContent = "Outstanding! You really know your stuff!";
            } else if (score >= 3) {
                resultsTitle.textContent = "Good Job!";
                resultsMessage.textContent = "Solid performance! Keep learning!";
            } else if (score >= 2) {
                resultsTitle.textContent = "Not Bad!";
                resultsMessage.textContent = "Room for improvement. Don't give up!";
            } else {
                resultsTitle.textContent = "Keep Trying!";
                resultsMessage.textContent = "Every expert was once a beginner.";
            }

            // Animate circle
            const circle = document.getElementById('resultsCircle');
            const percentage = (score / 5) * 100;
            const circumference = 565;
            const offset = circumference - (percentage / 100) * circumference;
            
            setTimeout(() => {
                circle.style.strokeDashoffset = offset;
            }, 100);
        }

        // Review Answers
        function reviewAnswers() {
            document.getElementById('resultsScreen').classList.remove('active');
            document.getElementById('quizScreen').classList.add('active');
            
            // Disable option clicks
            document.querySelectorAll('.option').forEach(opt => {
                opt.classList.add('disabled');
            });
            
            // Show correct/incorrect
            const q = questions[currentQuestion];
            const options = document.querySelectorAll('.option');
            
            options.forEach((opt, index) => {
                if (index === q.correct) {
                    opt.classList.add('correct');
                } else if (answers[currentQuestion] === index && index !== q.correct) {
                    opt.classList.add('incorrect');
                }
            });

            // Hide nav buttons in review mode
            document.getElementById('prevBtn').style.display = 'none';
            document.getElementById('nextBtn').style.display = 'none';
        }

        // Restart Quiz
        function restartQuiz() {
            currentQuestion = 0;
            answers = new Array(questions.length).fill(null);
            score = 0;
            timeRemaining = 300;

            document.getElementById('resultsScreen').classList.remove('active');
            document.getElementById('startScreen').classList.add('active');
            document.getElementById('prevBtn').style.display = 'flex';
            document.getElementById('nextBtn').style.display = 'flex';
            
            // Reset circle
            document.getElementById('resultsCircle').style.strokeDashoffset = 565;
        }
    </script>
</body>
</html>
