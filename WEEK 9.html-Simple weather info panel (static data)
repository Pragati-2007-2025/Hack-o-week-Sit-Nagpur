    <script>
        // Update time
        function updateTime() {
            const now = new Date();
            const options = { 
                hour: '2-digit', 
                minute: '2-digit',
                hour12: true 
            };
            document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-US', options);
            
            const updateOptions = {
                hour: '2-digit',
                minute: '2-digit',
                hour12: true
            };
            document.getElementById('lastUpdated').textContent = now.toLocaleTimeString('en-US', updateOptions);
        }

        updateTime();
        setInterval(updateTime, 1000);

        // Simulated weather refresh
        setInterval(() => {
            const temps = [23, 24, 25];
            const randomTemp = temps[Math.floor(Math.random() * temps.length)];
            
            // Subtle animation on temp change
            const featuredTemp = document.querySelector('.featured .temperature');
            if (featuredTemp) {
                featuredTemp.style.opacity = '0.5';
                setTimeout(() => {
                    featuredTemp.style.opacity = '1';
                }, 200);
            }
        }, 30000);
    </script>
</body>
</html>
