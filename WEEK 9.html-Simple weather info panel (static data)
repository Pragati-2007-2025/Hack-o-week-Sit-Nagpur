<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SKYCAST | Weather Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-card: #1e293b;
            --bg-gradient: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --accent-blue: #38bdf8;
            --accent-amber: #fbbf24;
            --accent-rose: #fb7185;
            --accent-emerald: #34d399;
            --accent-violet: #a78bfa;
            --radius-lg: 24px;
            --radius-md: 16px;
            --radius-sm: 12px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
            line-height: 1.5;
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-effects {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }

        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.4;
        }

        .bg-orb:nth-child(1) {
            width: 600px;
            height: 600px;
            background: var(--accent-blue);
            top: -200px;
            right: -100px;
            animation: orbFloat 25s ease-in-out infinite;
        }

        .bg-orb:nth-child(2) {
            width: 400px;
            height: 400px;
            background: var(--accent-violet);
            bottom: -100px;
            left: -100px;
            animation: orbFloat 20s ease-in-out infinite reverse;
        }

        .bg-orb:nth-child(3) {
            width: 300px;
            height: 300px;
            background: var(--accent-amber);
            top: 50%;
            left: 50%;
            animation: orbFloat 30s ease-in-out infinite;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(50px, -30px) scale(1.1); }
            50% { transform: translate(-30px, 50px) scale(0.9); }
            75% { transform: translate(-50px, -20px) scale(1.05); }
        }

        /* Main Container */
        .container {
            position: relative;
            z-index: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        .header {
            text-align: center;
            padding: 2rem 0 3rem;
        }

        .logo {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .logo-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-violet));
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2rem;
            font-weight: 600;
            letter-spacing: -0.02em;
        }

        .header-subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .current-time {
            color: var(--accent-blue);
            font-weight: 500;
            margin-left: 0.5rem;
        }

        /* Weather Cards Grid */
        .weather-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            flex: 1;
        }

        /* Weather Card */
        .weather-card {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            padding: 2rem;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }

        .weather-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        }

        .weather-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        }

        .weather-card.sunny::before {
            background: linear-gradient(90deg, var(--accent-amber), var(--accent-rose));
        }

        .weather-card.cloudy::before {
            background: linear-gradient(90deg, var(--text-muted), var(--accent-blue));
        }

        .weather-card.rainy::before {
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-violet));
        }

        .card-bg-icon {
            position: absolute;
            top: -20px;
            right: -20px;
            font-size: 12rem;
            opacity: 0.05;
            line-height: 1;
        }

        /* City Info */
        .city-info {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
        }

        .city-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .city-country {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .weather-icon {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
        }

        /* Main Temperature */
        .temperature-section {
            margin-bottom: 2rem;
        }

        .temperature {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 4.5rem;
            font-weight: 600;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .temperature span {
            font-size: 2rem;
            color: var(--text-secondary);
            font-weight: 400;
        }

        .weather-desc {
            font-size: 1.1rem;
            color: var(--text-secondary);
            text-transform: capitalize;
        }

        /* Weather Details */
        .weather-details {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .detail-item {
            text-align: center;
        }

        .detail-icon {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.05);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 0.5rem;
            color: var(--accent-blue);
        }

        .detail-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.2rem;
        }

        .detail-label {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Featured Card */
        .weather-card.featured {
            grid-column: span 2;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            align-items: center;
            padding: 3rem;
        }

        .featured .card-left {
            position: relative;
        }

        .featured .temperature {
            font-size: 6rem;
        }

        .featured .weather-icon {
            width: 100px;
            height: 100px;
            font-size: 4rem;
        }

        .featured .city-name {
            font-size: 2rem;
        }

        /* Hourly Forecast */
        .hourly-section {
            grid-column: span 1;
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            padding: 2rem;
        }

        .hourly-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 1.5rem;
        }

        .hourly-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .hourly-item:last-child {
            border-bottom: none;
        }

        .hourly-time {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .hourly-icon {
            font-size: 1.5rem;
        }

        .hourly-temp {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600;
        }

        /* Weekly Preview */
        .weekly-section {
            grid-column: 1 / -1;
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            padding: 2rem;
            margin-top: 1.5rem;
        }

        .weekly-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .weekly-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 1rem;
        }

        .day-card {
            text-align: center;
            padding: 1rem;
            background: rgba(255,255,255,0.02);
            border-radius: var(--radius-md);
            transition: all 0.3s ease;
        }

        .day-card:hover {
            background: rgba(255,255,255,0.05);
            transform: translateY(-3px);
        }

        .day-card.today {
            background: linear-gradient(135deg, rgba(56, 189, 248, 0.15), rgba(167, 139, 250, 0.15));
            border: 1px solid rgba(56, 189, 248, 0.3);
        }

        .day-name {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.75rem;
        }

        .day-card.today .day-name {
            color: var(--accent-blue);
        }

        .day-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .day-temps {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1rem;
            display: flex;
            justify-content: center;
            gap: 0.5rem;
        }

        .day-temp-high {
            font-weight: 600;
        }

        .day-temp-low {
            color: var(--text-muted);
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 2rem 0;
            color: var(--text-muted);
            font-size: 0.85rem;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .weather-grid {
                grid-template-columns: 1fr;
            }

            .weather-card.featured {
                grid-column: span 1;
                grid-template-columns: 1fr;
            }

            .hourly-section {
                order: -1;
            }

            .weekly-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        @media (max-width: 640px) {
            .container {
                padding: 1rem;
            }

            .temperature {
                font-size: 3.5rem;
            }

            .featured .temperature {
                font-size: 4rem;
            }

            .weekly-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 0.75rem;
            }

            .weather-details {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .weather-card, .hourly-section, .weekly-section {
            animation: fadeInUp 0.6s ease forwards;
        }

        .weather-card:nth-child(1) { animation-delay: 0.1s; }
        .weather-card:nth-child(2) { animation-delay: 0.2s; }
        .weather-card:nth-child(3) { animation-delay: 0.3s; }
    </style>
</head>
